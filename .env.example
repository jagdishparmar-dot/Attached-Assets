# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dms

# Local dev ports (Replit sets PORT / BASE_PATH via artifact.toml instead)
API_PORT=8080
ADMIN_PORT=5173
BASE_PATH=/admin/

SESSION_SECRET=change-me

# Required for API server startup. Replace with real OpenAI credentials to use /api/ai/*.
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
AI_INTEGRATIONS_OPENAI_API_KEY=

# Docker / production (docker-compose.yml)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=dms
HTTP_PORT=80
# Set to true when serving over HTTPS (required for secure admin cookies in production)
COOKIE_SECURE=false
# Run drizzle schema push on container start (set false after first deploy)
RUN_DB_MIGRATION=true
# Seed hubs + staff on container start (first deploy only; uses onConflictDoNothing)
RUN_DB_SEED=true
